# Copy this file to .env and fill in your key:  cp .env.example .env
#
# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# SQLite by default — no setup needed. Leave as-is for local use.
DATABASE_URL=sqlite:///./cerebro.db

# Below which confidence a verdict is treated as "needs review"
CONFIDENCE_THRESHOLD=0.75
